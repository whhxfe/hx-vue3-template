{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": ".",
		"types": ["node"],
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"],
			"@db/*": ["db/*"],
			"@routes/*": ["routes/*"],
			"@utils/*": ["utils/*"]
		}
	},
	"include": ["./**/*.ts"]
}